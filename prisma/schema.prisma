generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum TournamentStatus {
  DRAFT
  ONGOING
  COMPLETED
}

model Tournament {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?          @db.Text
  bannerUrl   String?          @db.Text
  backgroundUrl String?        @db.Text
  startDate   DateTime
  endDate     DateTime
  maxSlots    Int              @default(32)
  prizePool   String?
  status      TournamentStatus @default(DRAFT)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  teams       Team[]
  matches     Match[]

  @@map("tournaments")
}

enum TeamStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PlayerRole {
  CAPTAIN
  MEMBER
  STANDBY
}

enum MatchStatus {
  SCHEDULED
  ONGOING
  COMPLETED
}

model Team {
  id           String       @id @default(cuid())
  name         String       @unique
  tag          String       @unique
  logoUrl      String?
  status       TeamStatus   @default(PENDING)
  tournamentId String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tournament   Tournament?  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  players      Player[]
  matchResults MatchResult[]

  @@index([tournamentId])
  @@map("teams")
}

model Player {
  id          String     @id @default(cuid())
  ign         String
  inGameId    String     @unique
  steamId     String?    @unique
  role        PlayerRole @default(MEMBER)
  teamId      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  team        Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@map("players")
}

model Match {
  id          String      @id @default(cuid())
  scheduledAt DateTime
  group       String
  map         String
  status      MatchStatus @default(SCHEDULED)
  tournamentId String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matchResults MatchResult[]

  @@index([tournamentId])
  @@map("matches")
}

model MatchResult {
  id             String   @id @default(cuid())
  killPoints     Int      @default(0)
  placementPoints Int     @default(0)
  totalPoints    Int      @default(0)
  finishPosition Int
  isWwcd         Boolean  @default(false)
  teamId         String
  matchId        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  match          Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([teamId, matchId])
  @@index([teamId])
  @@index([matchId])
  @@map("match_results")
}

enum UserRole {
  ADMIN
  SUPERADMIN
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      UserRole @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model ScoringConfig {
  id              String   @id @default(cuid())
  rank            Int      @unique
  placementPoints Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("scoring_configs")
}

model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("app_settings")
}
