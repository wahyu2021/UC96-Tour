generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum TournamentStatus {
  DRAFT
  ONGOING
  COMPLETED
}

model Tournament {
  id            String           @id @default(cuid())
  name          String           @unique
  description   String?          @db.Text
  bannerUrl     String?          @db.Text
  backgroundUrl String?          @db.Text
  startDate     DateTime
  endDate       DateTime
  maxSlots      Int              @default(32)
  prizePool     String?
  status        TournamentStatus @default(DRAFT)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  registrations TournamentRegistration[]
  matches       Match[]

  @@map("tournaments")
}

enum TeamStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PlayerRole {
  CAPTAIN
  MEMBER
  STANDBY
}

enum MatchStatus {
  SCHEDULED
  ONGOING
  COMPLETED
}

model Team {
  id           String     @id @default(cuid())
  name         String     @unique
  tag          String     @unique
  logoUrl      String?
  ownerId      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  owner         User?                    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  players       Player[]
  matchResults  MatchResult[]
  registrations TournamentRegistration[]

  @@index([ownerId])
  @@map("teams")
}

model TournamentRegistration {
  id           String     @id @default(cuid())
  teamId       String
  tournamentId String
  status       TeamStatus @default(PENDING)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([teamId, tournamentId])
  @@index([teamId])
  @@index([tournamentId])
  @@map("tournament_registrations")
}

model Player {
  id        String     @id @default(cuid())
  ign       String
  inGameId  String     @unique
  steamId   String?    @unique
  role      PlayerRole @default(MEMBER)
  teamId    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@map("players")
}

model Match {
  id           String      @id @default(cuid())
  scheduledAt  DateTime
  group        String
  map          String
  status       MatchStatus @default(SCHEDULED)
  tournamentId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tournament   Tournament?   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matchResults MatchResult[]

  @@index([tournamentId])
  @@map("matches")
}

model MatchResult {
  id              String   @id @default(cuid())
  killPoints      Int      @default(0)
  placementPoints Int      @default(0)
  totalPoints     Int      @default(0)
  finishPosition  Int
  isWwcd          Boolean  @default(false)
  teamId          String
  matchId         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  team  Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([teamId, matchId])
  @@index([teamId])
  @@index([matchId])
  @@map("match_results")
}

enum UserRole {
  PLAYER
  ADMIN
  SUPERADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  username      String?   @unique
  password      String?
  role          UserRole  @default(PLAYER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  teams    Team[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model ScoringConfig {
  id              String   @id @default(cuid())
  rank            Int      @unique
  placementPoints Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("scoring_configs")
}

model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("app_settings")
}
